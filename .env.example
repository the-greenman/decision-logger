# Database (host port 5433 matches docker-compose ports: "5433:5432")
DATABASE_URL=postgresql://decision_logger:decision_logger@localhost:5433/decision_logger_dev
TEST_DATABASE_URL=postgresql://decision_logger:decision_logger@localhost:5433/decision_logger_test

# LLM Provider (choose one)
ANTHROPIC_API_KEY=sk-ant-your-key-here
# OPENAI_API_KEY=sk-your-key-here

# LLM Configuration
# LLM_PROVIDER: "anthropic" | "openai" | "ollama" | "openai-compatible"
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus-4-5
USE_TEMPLATE_PROMPT=false

# Local / self-hosted models (Ollama, vLLM, LM Studio, llama.cpp server, LocalAI, …)
# Set LLM_PROVIDER=ollama and pick a capable instruct model that can emit JSON.
# Recommended: gpt-oss:20b  (best structured-output quality in this size class)
# Alternatives: qwen2.5:14b-instruct, llama3.1:8b-instruct, mistral-nemo
#
# Example — Ollama running on the host (default):
#   LLM_PROVIDER=ollama
#   LLM_MODEL=gpt-oss:20b
#   LLM_BASE_URL=http://localhost:11434/v1   # defaults to this when provider=ollama
#   LLM_API_KEY=not-needed                    # Ollama ignores it; any non-empty value works
#
# Example — generic OpenAI-compatible endpoint (vLLM / LM Studio / llama.cpp):
#   LLM_PROVIDER=openai-compatible
#   LLM_MODEL=Qwen/Qwen2.5-14B-Instruct
#   LLM_BASE_URL=http://localhost:8080/v1
#   LLM_API_KEY=your-key-or-dummy

# Docker Compose note:
# docker compose reads these values from your shell or .env file.
# Keep API keys out of docker-compose.yml.
# Example (hosted):
#   export ANTHROPIC_API_KEY=your-key-here
#   export LLM_PROVIDER=anthropic
#   export LLM_MODEL=claude-opus-4-5
#   docker compose up --build api
# Example (local Ollama on host, API in compose):
#   export LLM_PROVIDER=ollama
#   export LLM_MODEL=gpt-oss:20b
#   export LLM_BASE_URL=http://host.docker.internal:11434/v1
#   docker compose up --build api

# API Configuration
API_PORT=3000
API_HOST=localhost

# CLI Configuration (M5+: CLI talks to the API, not the DB directly)
# Point at local dev server or a remote deployed instance
DECISION_LOGGER_API_URL=http://localhost:3000

# Environment
NODE_ENV=development
